NODE_ENV=production
PORT=3000
MONGO_URI=mongodb+srv://replace-with-production-mongo-uri
TENANT_ID=replace-with-tenant-id
TENANT_NAME=replace-with-tenant-name
DEPLOYMENT_ENVIRONMENT=production
SUPABASE_DEPLOYMENT_MODE=self-hosted
SUPABASE_SELF_HOSTED_ENV_FILE=deploy/self-hosted-supabase/.env
NEXUS_DOMAIN=arcade.example.com
NEXUS_APP_DOMAIN=arcade.example.com
NEXUS_API_DOMAIN=api.arcade.example.com
NEXUS_IDENTITY_DOMAIN=identity.arcade.example.com
NEXUS_LETSENCRYPT_EMAIL=admin@example.com
APP_BASE_URL=https://arcade.example.com
API_BASE_URL=https://api.arcade.example.com
IDENTITY_PROVIDER=supabase
SUPABASE_PROJECT_URL=https://identity.arcade.example.com
IDENTITY_ISSUER=https://identity.arcade.example.com/auth/v1
IDENTITY_JWKS_URL=https://identity.arcade.example.com/auth/v1/.well-known/jwks.json
IDENTITY_AUDIENCE=authenticated
VITE_IDENTITY_PROVIDER=supabase
VITE_SUPABASE_URL=https://identity.arcade.example.com
VITE_SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-publishable-key
VITE_SUPABASE_ANON_KEY=
QR_SESSION_TTL_SECONDS=300
CABINET_ID=replace-with-cabinet-id
SITE_ID=replace-with-site-id
GODOT_NEXUS_RELAY_PATH=
GODOT_COMMAND_PATH=
GODOT_NEXUS_RELAY_PROJECT_PATH=
GAME_CALLBACK_SECRET=replace-with-strong-production-game-callback-secret
GAME_CALLBACK_PORT=43871
SYNC_QUEUE_PATH=apps/hub/.runtime/sync-queue.jsonl
PASSPORT_TOKEN_SECRET=replace-with-strong-production-passport-token-secret
OAUTH_ISSUER=https://api.arcade.example.com
TWO_FACTOR_TTL_SECONDS=300
TWO_FACTOR_MAX_ATTEMPTS=5
EXPOSE_DEV_2FA_CODES=false
OPERATOR_ID=operator
OPERATOR_PIN=replace-with-strong-operator-pin
OPERATOR_SESSION_TTL_SECONDS=28800
