{
  "name": "nexus-arcade-hub",
  "version": "0.1.0",
  "type": "module",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently -n vite,electron -c cyan,yellow \"vite --host 127.0.0.1 --port 5174\" \"wait-on http://127.0.0.1:5174 && electron .\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5174",
    "start": "electron .",
    "build": "vite build && node --check src/main/main.js",
    "test": "node --test src/tests/*.test.js"
  },
  "dependencies": {
    "nexus-arcade-shared": "0.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "electron": "^41.4.0",
    "lucide-react": "^0.468.0",
    "socket.io-client": "^4.8.1",
    "dotenv": "^16.4.7"
  }
}
